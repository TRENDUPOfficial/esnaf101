# Postgres
DATABASE_URL="postgresql://esnaf101:esnaf101@localhost:5432/esnaf101?schema=public"

# Redis / BullMQ
REDIS_URL="redis://localhost:6379"

# Tenant entegrasyon API anahtarlarını (Parasut/Shipentegra/WhatsApp) DB'ye
# yazmadan önce şifrelemek için (bkz. @esnaf101/crypto). apps/api ve
# apps/worker'da birebir aynı olmalı — üretimde `openssl rand -base64 32` ile
# üretilip bir secret manager'da saklanmalı.
APP_ENCRYPTION_KEY=

# WhatsApp Cloud API (Meta) — platform tek bir Meta App üzerinden çalışır,
# her tenant'ın kendi numarası (phone_number_id) tenant_integrations
# tablosunda tutulur (bkz. PLANNING.md Adım 3). WHATSAPP_ACCESS_TOKEN,
# tenant_integrations.whatsappAccessToken tanımlı değilse platform genelinde
# kullanılan yedek (system user) token'dır.
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=

# Parasut (e-fatura) / Shipentegra (kargo): platform genelinde DEĞİL, her
# tenant kendi kimlik bilgisini panelden (apps/web /integrations) girer;
# TenantIntegration.invoiceCredentials/shippingCredentials'da APP_ENCRYPTION_KEY
# ile şifreli JSON olarak saklanır. Burada global env var yok.

# iyzico (abonelik faturalama — bu platformun KENDİ hesabı, tenant'lara göre
# değil; tenant'lardan otomatik tahsilat için kullanılır, bkz. PLANNING.md
# Adım 9). NOT: @esnaf101/integrations-billing'deki gerçek HMAC imzalama
# henüz yazılmadı (sandbox kimlik bilgisi olmadan doğrulanamaz) — bu yüzden
# bu değerler tanımlı olsa bile tahsilat denemeleri şu an başarısız olur.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Object storage (Cloudflare R2, S3 uyumlu). Tanımsız bırakılırsa
# @esnaf101/integrations-storage otomatik olarak yerel diske yazan
# LocalObjectStorage'a düşer (yalnızca dev/test) — apps/api ve apps/worker
# aynı LOCAL_STORAGE_DIR'ı kullanmalı (aksi halde biri yazdığını diğeri
# servis edemez).
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
LOCAL_STORAGE_DIR=../../.local-storage
LOCAL_STORAGE_PUBLIC_URL="http://localhost:3001/uploads"

# Auth (Clerk) — apps/api ve apps/web tarafından ortak kullanılır.
# Tenant = Clerk Organization; apps/web onboarding akışında organizasyon
# oluşturulunca apps/api/webhooks/clerk bunu bir Tenant satırına çevirir.
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Clerk Dashboard > Webhooks > endpoint'in "Signing Secret" değeri (whsec_...)
CLERK_WEBHOOK_SIGNING_SECRET=

# Süper admin oturum JWT'sini imzalamak için (apps/api). apps/superadmin'in
# buna ihtiyacı yok — sadece httpOnly cookie'de token'ı taşıyor, doğrulama
# her istekte apps/api tarafında yapılıyor.
PLATFORM_ADMIN_JWT_SECRET=

# apps/web / apps/superadmin -> apps/api istekleri için taban URL
NEXT_PUBLIC_API_URL="http://localhost:3001"

# apps/api CORS izin listesi — virgülle ayrılmış origin listesi
# (ör. "https://app.esnaf101.com,https://admin.esnaf101.com"). Tanımsız
# bırakılırsa dev'de sadece localhost'a izin verilir; NODE_ENV=production'da
# tanımsızsa uygulama başlamayı reddeder (bkz. apps/api/src/main.ts).
ALLOWED_ORIGINS=
